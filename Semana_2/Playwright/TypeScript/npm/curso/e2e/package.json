{
  "name": "dia2-playwright-typescript",
  "version": "1.0.0",
  "private": true,
  "description": "Ejemplos de POM, auto-esperas y assertions con Playwright + TypeScript.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.7.0",
    "typescript": "6.0.3"
  }
}
